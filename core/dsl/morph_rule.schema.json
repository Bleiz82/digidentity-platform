{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digidentity.dev/schemas/morph_rule.schema.json",
  "title": "MorphRuleFile",
  "description": "DSL schema for morph rule YAML files — BIBLE-v3 §8",
  "type": "object",
  "required": ["version", "target_page", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "target_page": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Rule" }
    },
    "fallback": {
      "type": "array",
      "items": { "$ref": "#/$defs/Directive" }
    }
  },
  "$defs": {
    "Rule": {
      "type": "object",
      "required": ["id", "priority", "when", "do"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "description": {
          "type": "string"
        },
        "when": { "$ref": "#/$defs/Condition" },
        "do": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Directive" }
        }
      }
    },
    "Condition": {
      "oneOf": [
        { "$ref": "#/$defs/SimpleCondition" },
        { "$ref": "#/$defs/MatchAllCondition" },
        { "$ref": "#/$defs/MatchAnyCondition" }
      ]
    },
    "SimpleCondition": {
      "type": "object",
      "required": ["signal"],
      "properties": {
        "signal": { "type": "string", "minLength": 1 },
        "gte": { "type": "number" },
        "lte": { "type": "number" },
        "gt": { "type": "number" },
        "lt": { "type": "number" },
        "equals": {},
        "equals_any": { "type": "array" },
        "matches_any": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "not": {
        "anyOf": [
          { "required": ["match_all"] },
          { "required": ["match_any"] }
        ]
      }
    },
    "MatchAllCondition": {
      "type": "object",
      "required": ["match_all"],
      "additionalProperties": false,
      "properties": {
        "match_all": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/SimpleCondition" }
        }
      }
    },
    "MatchAnyCondition": {
      "type": "object",
      "required": ["match_any"],
      "additionalProperties": false,
      "properties": {
        "match_any": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/SimpleCondition" }
        }
      }
    },
    "DirectiveType": {
      "type": "string",
      "enum": [
        "morph_section",
        "highlight",
        "inject",
        "show",
        "hide",
        "reorder",
        "rewrite_copy",
        "set_persona",
        "spatial_navigate",
        "trigger_agent",
        "track",
        "render_default"
      ]
    },
    "Directive": {
      "type": "object",
      "required": ["directive"],
      "additionalProperties": false,
      "properties": {
        "directive": { "$ref": "#/$defs/DirectiveType" },
        "target": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      }
    }
  }
}
